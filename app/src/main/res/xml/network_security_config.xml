<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 默认拒绝明文 HTTP,仅允许 HTTPS -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- 常用中国高校教务 HTTPS 域名白名单(仅作为示例,可按需添加pin-set) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">jwgl.bupt.edu.cn</domain>
        <domain includeSubdomains="true">my.cqu.edu.cn</domain>
    </domain-config>

    <!-- BUG-001 维修(2026-07-11):韶关学院教务系统(湖南强智科技 HTTP-only 部署,
         登录入口 http://jwc.sgu.edu.cn/Logon.do)被 base-config cleartextTrafficPermitted="false"
         全网阻断,WebView 报 net::ERR_CLEARTEXT_NOT_PERMITTED,用户看到 Chromium 默认红色错误页。
         显式放行 sgu.edu.cn 的明文流量;HTTPS-only 域名行为不变。 -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">sgu.edu.cn</domain>
    </domain-config>
</network-security-config>
