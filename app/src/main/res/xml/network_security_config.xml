<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 默认拒绝明文 HTTP,仅允许 HTTPS -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- 常用中国高校教务 HTTPS 域名白名单(仅作为示例,可按需添加pin-set) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">jwgl.bupt.edu.cn</domain>
        <domain includeSubdomains="true">my.cqu.edu.cn</domain>
    </domain-config>
</network-security-config>
